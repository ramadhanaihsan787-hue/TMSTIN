# ==========================================
# FRONTEND — Template Konfigurasi
# ==========================================

# --- API ---
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# --- AUTH ---
VITE_TOKEN_KEY=auth_token
VITE_TOKEN_REFRESH_INTERVAL=3600000

# --- APP ---
VITE_ENV=development
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=TMS Japfa FnB

# --- THIRD-PARTY KEYS ---
# Mapbox: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.eyJ...ISI_TOKEN_MAPBOX_KAMU

# TomTom (sama dengan Backend jika dipakai di frontend juga)
VITE_TOMTOM_API_KEY=ISI_API_KEY_TOMTOM_KAMU

# --- FEATURES ---
VITE_ENABLE_3D_PLANNER=true
VITE_ENABLE_POD=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_MAP=true

# --- UI ---
VITE_DEFAULT_THEME=light
VITE_ENABLE_ANIMATIONS=true
VITE_ITEMS_PER_PAGE=10

# --- BUSINESS CONFIG ---
VITE_DEFAULT_DELIVERY_START=08:00
VITE_DEFAULT_DELIVERY_END=17:00
VITE_MAX_ORDER_WEIGHT=5000

# --- MONITORING (opsional) ---
VITE_SENTRY_DSN=
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=warn
