# ==========================================
# TMS JAPFA - GLOBAL ENVIRONMENT CONFIGURATION
# ==========================================
# 
# IMPORTANT: JANGAN COMMIT FILE .env KE GIT!
# Gunakan file ini sebagai referensi untuk membuat file .env di folder Backend dan Frontend.

# ==========================================
# BACKEND CONFIGURATION (.env in /Backend)
# ==========================================

# --- DATABASE ---
DATABASE_URL=....

# --- JWT AUTH ---
SECRET_KEY=....
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- EXTERNAL SERVICES ---
TOMTOM_API_KEY=....
TRAFFIC_VALIDATION_ENABLED=true

# --- APP CONFIG ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ==========================================
# FRONTEND CONFIGURATION (.env in /Frontend)
# ==========================================

# --- API CONFIGURATION ---
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# --- AUTHENTICATION ---
VITE_TOKEN_KEY=auth_token
VITE_TOKEN_REFRESH_INTERVAL=3600000

# --- APPLICATION CONFIG ---
VITE_ENV=development
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=TMS Japfa FnB

# --- THIRD-PARTY SERVICES ---
VITE_GOOGLE_MAPS_KEY=
VITE_TOMTOM_API_KEY=
VITE_MAPBOX_TOKEN=

# --- LOGGING & DEBUGGING ---
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug

# --- FEATURES TOGGLES ---
VITE_ENABLE_3D_PLANNER=true
VITE_ENABLE_POD=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_MAP=true

# --- UI CONFIGURATION ---
VITE_DEFAULT_THEME=light
VITE_ENABLE_ANIMATIONS=true
VITE_ITEMS_PER_PAGE=10

# --- SECURITY ---
VITE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
VITE_HTTPS_ONLY=false

# --- MONITORING & ANALYTICS ---
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=

# --- BUSINESS CONFIG ---
VITE_DEFAULT_DELIVERY_START=08:00
VITE_DEFAULT_DELIVERY_END=17:00
VITE_MAX_ORDER_WEIGHT=5000
VITE_MAX_ORDER_VOLUME=50
